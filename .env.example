# Variáveis opcionais. Sem um arquivo .env, os valores padrão (abaixo) são usados,
# então o projeto sobe com "docker compose up" sem nenhuma configuração.

# Para customizar: copie este arquivo para .env e ajuste os valores.
#   cp .env.example .env

# Credenciais do banco (usadas tanto pelo PostgreSQL quanto pela aplicação)
DB_NAME=agendamentos
DB_USER=app
DB_PASSWORD=app

# Portas expostas no host (caso as padrões 8000 e 5432 estejam ocupadas)
APP_PORT=8000
DB_HOST_PORT=5432
